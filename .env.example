# --- Required ---
FLASK_SECRET_KEY=
ADMIN_USERNAME=
# Provide ONE of the following admin password options.
# Preferred: a Werkzeug password hash (generate with:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('your-password'))")
ADMIN_PASSWORD_HASH=
# Fallback (plaintext) — used only if ADMIN_PASSWORD_HASH is unset.
ADMIN_PASSWORD=

# --- Database ---
# First non-empty of these is used (see database.get_database_url):
DATABASE_URL=
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# Or compose from parts: PGHOST/PGUSER/PGPASSWORD/PGDATABASE (or POSTGRES_* equivalents)

# --- Cache (optional) ---
REDIS_URL=

# --- Analytics / error tracking (optional) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=

# --- Dev toggles (optional) ---
# FLASK_ENV=development
# FLASK_DEBUG=1

# Search uses Postgres full-text search. No extra service required.
# The search_vector column is created automatically by init_db().
