{
	"version": 2,
	"git": {
		"deploymentEnabled": false
	},
	"builds": [
		{
			"src": "app.py",
			"use": "@vercel/python"
		},
		{
			"src": "static/**",
			"use": "@vercel/static"
		}
	],
	"routes": [
		{
			"src": "/_vercel/(.*)",
			"dest": "/_vercel/$1"
		},
		{
			"src": "/static/(.*)",
			"headers": { "cache-control": "public, max-age=31536000, immutable" },
			"dest": "/static/$1"
		},
		{
			"src": "/(.*)",
			"dest": "app.py"
		}
	]
}
